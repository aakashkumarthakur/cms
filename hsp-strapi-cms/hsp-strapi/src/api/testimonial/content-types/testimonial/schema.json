{
  "kind": "collectionType",
  "collectionName": "testimonials",
  "info": {
    "singularName": "testimonial",
    "pluralName": "testimonials",
    "displayName": "Testimonial",
    "description": "Guest reviews and ratings for Hotel Sujata Palace"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "guestName": {
      "type": "string",
      "required": true,
      "maxLength": 100
    },
    "location": {
      "type": "string",
      "maxLength": 100,
      "comment": "e.g. Kathmandu, Nepal or Delhi, India"
    },
    "review": {
      "type": "text",
      "required": true,
      "maxLength": 1000
    },
    "rating": {
      "type": "integer",
      "required": true,
      "min": 1,
      "max": 5,
      "default": 5
    },
    "stayDate": {
      "type": "date",
      "comment": "When the guest stayed"
    },
    "roomType": {
      "type": "string",
      "maxLength": 100,
      "comment": "Which room type they stayed in"
    },
    "avatar": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"],
      "comment": "Guest photo (optional)"
    },
    "source": {
      "type": "enumeration",
      "enum": [
        "Direct",
        "Google",
        "TripAdvisor",
        "Booking.com",
        "Facebook",
        "Other"
      ],
      "default": "Direct"
    },
    "isFeatured": {
      "type": "boolean",
      "default": false,
      "comment": "Show on homepage"
    }
  }
}
