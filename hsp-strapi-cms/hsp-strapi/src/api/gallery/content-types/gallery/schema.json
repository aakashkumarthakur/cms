{
  "kind": "collectionType",
  "collectionName": "galleries",
  "info": {
    "singularName": "gallery",
    "pluralName": "galleries",
    "displayName": "Gallery",
    "description": "Hotel photo gallery organized by category"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "maxLength": 150
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": ["images"]
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "Rooms",
        "Restaurant",
        "Banquet Hall",
        "Exterior",
        "Lobby",
        "Amenities",
        "Events",
        "Other"
      ],
      "required": true,
      "default": "Exterior"
    },
    "altText": {
      "type": "string",
      "maxLength": 200,
      "comment": "Alt text for accessibility and SEO"
    },
    "caption": {
      "type": "text",
      "maxLength": 300
    },
    "isFeatured": {
      "type": "boolean",
      "default": false,
      "comment": "Show on homepage gallery section"
    },
    "sortOrder": {
      "type": "integer",
      "default": 0
    }
  }
}
